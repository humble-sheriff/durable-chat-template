{
	"compatibility_date": "2025-10-08",
	"main": "src/server/index.ts",
	"name": "durable-chat-template",
	"migrations": [
		{
			"new_sqlite_classes": [
				"Chat"
			],
			"tag": "v1"
		}
	],
	"assets": {
		"directory": "./public",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application"
	},
	"build": {
		"command": "esbuild src/client/index.tsx --bundle --splitting --format=esm --platform=browser --outdir=public/dist"
	},
	"durable_objects": {
		"bindings": [
			{
				"class_name": "Chat",
				"name": "Chat"
			}
		]
	},
	"kv_namespaces": [
		{
			"binding": "LFG_BOARD",
			"id": "83ddc11601bb42d39b0defdc3866c25d"
		}
	],
	"d1_databases": [
		{
			"binding": "PLAYER_DB",
			"database_name": "player-db",
			"database_id": "de80a2f5-1ea7-42e5-b9bb-d61b8d39ef42"
		}
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}